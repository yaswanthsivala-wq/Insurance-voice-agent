# Copy this file to ".env" and fill in your keys.

# --- Groq (required) --- get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# --- Supabase (optional) --- permanent history storage.
# Leave BOTH blank to use a local SQLite file instead (fine for local dev).
# Find these in your Supabase project: Connect dialog, or Settings > API Keys.
# Use a SECRET key (sb_secret_...) — it is server-side only, never sent to the browser.
SUPABASE_URL=
SUPABASE_KEY=

# --- Optional overrides ---
# STT_MODEL=whisper-large-v3-turbo
# LLM_MODEL=llama-3.3-70b-versatile
# DATABASE_PATH=intakes.db
